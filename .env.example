# MongoDB connection string (local mongod or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/sixtusagbo-blog

# Secret for signing admin session JWTs (openssl rand -hex 32)
AUTH_SECRET=

# Admin panel credentials
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary (optional) - enables image upload in the admin editor.
# Create an unsigned upload preset in your Cloudinary dashboard.
# When unset, the editor falls back to pasting an image URL.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
